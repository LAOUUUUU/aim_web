{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aim-web",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-27",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aim-web-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
